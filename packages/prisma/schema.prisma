datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client-js"
}

// ===========================================================================
// USER & AUTHENTICATION
// ===========================================================================
model User {
    id                            String                         @id @default(uuid())
    name                          String
    surname                       String
    email                         String                         @unique
    emailVerified                 Boolean                        @default(false)
    onBoardingStep                OnBoardingStep                 @default(GENERALITES)
    onBoardingAt                  DateTime?
    image                         String?
    snapshotFrequency             SnapshotFrequency              @default(MONTHLY)
    // User Configuration Settings
    preferredCurrency             Currency                       @default(EUR)
    preferredLanguage             Language                       @default(EN)
    dateFormat                    DateFormat                     @default(DD_MM_YYYY)
    country                       Countries                      @default(ITALY)
    timezone                      Timezone                       @default(ETC_UTC)
    preferredMarketDataProviderId String?                        @default("yahoo-finance")
    //Other
    createdAt                     DateTime                       @default(now())
    updatedAt                     DateTime                       @updatedAt
    deletedAt                     DateTime?                      @db.Timestamptz
    transactions                  Transaction[]
    transfers                     Transfer[]
    subscriptions                 Subscription[]
    categories                    Category[]
    financialAccounts             FinancialAccount[]
    imports                       Import[]
    sessions                      Session[]
    accounts                      Account[]
    verifications                 Verification[]
    assets                        Asset[]
    liabilities                   Liability[]
    snapshots                     Snapshot[]
    dashboardLayout               DashboardLayout?
    marketDataCredentials         MarketDataProviderCredential[]

    @@index([surname])
    @@index([createdAt])
    @@index([email])
}

model DashboardLayout {
    id        String   @id @default(uuid())
    userId    String   @unique
    version   Int      @default(1)
    layout    Json
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

model Session {
    id        String   @id @default(uuid())
    token     String   @unique
    userId    String
    expiresAt DateTime
    ipAddress String?
    userAgent String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([token])
}

model Account {
    id                    String    @id @default(uuid())
    accountId             String    @unique
    providerId            String
    userId                String
    accessToken           String?
    refreshToken          String?
    idToken               String?
    accessTokenExpiresAt  DateTime?
    refreshTokenExpiresAt DateTime?
    scope                 String?
    password              String?
    createdAt             DateTime  @default(now())
    updatedAt             DateTime  @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
}

model Verification {
    id         String   @id @default(uuid())
    identifier String
    value      String
    expiresAt  DateTime
    userId     String?
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([identifier, value])
    @@index([identifier])
    @@index([expiresAt])
    @@index([userId])
}

// ===========================================================================
// FINANCIAL ACCOUNTS
// ===========================================================================
model FinancialAccount {
    id                    String                   @id @default(uuid())
    userId                String
    title                 String
    balance               Decimal                  @default(0) @db.Decimal(20, 2)
    type                  FinancialAccountType     @default(BANK_ACCOUNT)
    logoIcon              String?
    createdAt             DateTime                 @default(now())
    updatedAt             DateTime                 @updatedAt
    deletedAt             DateTime?                @db.Timestamptz
    subscriptions         Subscription[]
    amounts               Amount[]
    imports               Import[]
    snapshotBalances      SnapshotAccountBalance[]
    assetTransactions     AssetTransaction[]
    liabilities           Liability[]
    liabilityTransactions LiabilityTransaction[]

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("FinancialAccounts")
}

// ===========================================================================
// ASSET SYSTEM
// ===========================================================================
model Asset {
    id               String               @id @default(uuid())
    userId           String
    title            String
    type             AssetType
    currency         Currency             @default(EUR)
    currentValue     Decimal?             @db.Decimal(20, 2)
    currentValueAsOf DateTime?
    createdAt        DateTime             @default(now())
    updatedAt        DateTime             @updatedAt
    deletedAt        DateTime?            @db.Timestamptz
    marketable       MarketableAsset?
    realEstate       RealEstateAsset?
    collectible      CollectibleAsset?
    privateDeal      PrivateDealAsset?
    vehicle          VehicleAsset?
    insurance        InsuranceAsset?
    transactions     AssetTransaction[]
    snapshotValues   SnapshotAssetValue[]

    user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
    autoDepreciations AutoDepreciation[]

    @@index([userId, type])
    @@index([userId, deletedAt])
}

model MarketableAsset {
    id            String                @id @default(uuid())
    assetId       String                @unique
    symbol        String?
    isin          String?
    exchange      String?
    assetClass    MarketableAssetClass?
    sector        String?
    region        String?
    lastPriceSync DateTime?
    createdAt     DateTime              @default(now())
    updatedAt     DateTime              @updatedAt
    deletedAt     DateTime?             @db.Timestamptz

    asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

    @@index([symbol])
    @@index([isin])
}

model RealEstateAsset {
    id            String         @id @default(uuid())
    assetId       String         @unique
    address       String?
    type          RealEstateType
    purchasePrice Decimal?       @db.Decimal(20, 2)
    purchaseDate  DateTime?
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt
    deletedAt     DateTime?      @db.Timestamptz

    asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model CollectibleAsset {
    id              String    @id @default(uuid())
    assetId         String    @unique
    acquisitionCost Decimal?  @db.Decimal(20, 2)
    acquisitionDate DateTime?
    appraisalValue  Decimal?  @db.Decimal(20, 2)
    appraisalDate   DateTime?
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt
    deletedAt       DateTime? @db.Timestamptz

    asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model PrivateDealAsset {
    id              String    @id @default(uuid())
    assetId         String    @unique
    committedAmount Decimal?  @db.Decimal(20, 2)
    calledAmount    Decimal?  @db.Decimal(20, 2)
    latestNav       Decimal?  @db.Decimal(20, 2)
    navDate         DateTime?
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt
    deletedAt       DateTime? @db.Timestamptz

    asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model VehicleAsset {
    id            String          @id @default(uuid())
    assetId       String          @unique
    brand         String
    model         String
    type          VehicleType
    year          Int?
    purchasePrice Decimal?        @db.Decimal(20, 2)
    purchaseDate  DateTime?
    plateNumber   String?
    vin           String?
    mileage       Int?
    condition     AssetCondition?
    createdAt     DateTime        @default(now())
    updatedAt     DateTime        @updatedAt
    deletedAt     DateTime?       @db.Timestamptz

    asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model InsuranceAsset {
    id               String               @id @default(uuid())
    assetId          String               @unique
    insurer          String?
    policyType       InsurancePolicyType?
    policyNumber     String?
    startDate        DateTime?
    endDate          DateTime?
    beneficiary      String?
    premiumPaid      Decimal?             @db.Decimal(20, 2)
    premiumFrequency CyclePeriod?
    surrenderValue   Decimal?             @db.Decimal(20, 2)
    createdAt        DateTime             @default(now())
    updatedAt        DateTime             @updatedAt
    deletedAt        DateTime?            @db.Timestamptz

    asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AssetTransaction {
    id                 String               @id @default(uuid())
    assetId            String
    type               AssetTransactionType
    date               DateTime
    settlementDate     DateTime?
    quantityChange     Decimal?             @db.Decimal(20, 10)
    unitPrice          Decimal?             @db.Decimal(20, 8)
    totalAmount        Decimal?             @db.Decimal(20, 2)
    currency           Currency             @default(EUR)
    fxRate             Decimal?             @db.Decimal(20, 10)
    fees               Decimal?             @db.Decimal(10, 2)
    taxAmount          Decimal?             @db.Decimal(20, 2)
    financialAccountId String?
    note               String?
    createdAt          DateTime             @default(now())
    updatedAt          DateTime             @updatedAt
    deletedAt          DateTime?            @db.Timestamptz

    asset            Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
    financialAccount FinancialAccount? @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)

    @@index([assetId, type])
    @@index([assetId, date(sort: Desc)])
    @@index([financialAccountId])
}

model AutoDepreciation {
    id                String                @id @default(uuid())
    assetId           String
    startDate         DateTime
    endDate           DateTime?
    depreciationBase  DepreciationBase      @default(CURRENT_VALUE)
    depreciationType  DepreciationValueType @default(AMOUNT)
    depreciationValue Decimal               @db.Decimal(20, 4)
    cyclePeriod       CyclePeriod           @default(YEAR)
    cycleNumber       Int                   @default(1)
    createdAt         DateTime              @default(now())
    updatedAt         DateTime              @updatedAt
    deletedAt         DateTime?             @db.Timestamptz

    asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

    @@index([assetId, startDate, endDate])
}

// ===========================================================================
// LIABILITY SYSTEM (debts: mortgages, loans, credit lines)
// ===========================================================================
model Liability {
    id                 String            @id @default(uuid())
    userId             String
    title              String
    type               LiabilityType
    currency           Currency          @default(EUR)
    principalAmount    Decimal           @db.Decimal(20, 2)
    currentBalance     Decimal           @db.Decimal(20, 2)
    interestRate       Decimal?          @db.Decimal(8, 5)
    interestRateType   InterestRateType?
    startDate          DateTime
    endDate            DateTime?
    durationMonths     Int?
    monthlyPayment     Decimal?          @db.Decimal(20, 2)
    financialAccountId String?
    createdAt          DateTime          @default(now())
    updatedAt          DateTime          @updatedAt
    deletedAt          DateTime?         @db.Timestamptz

    mortgage         MortgageLiability?
    loan             LoanLiability?
    transactions     LiabilityTransaction[]
    snapshotBalances SnapshotLiabilityBalance[]

    user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
    financialAccount FinancialAccount? @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)

    @@index([userId, type])
    @@index([userId, deletedAt])
    @@index([financialAccountId])
}

model MortgageLiability {
    id                String       @id @default(uuid())
    liabilityId       String       @unique
    mortgageType      MortgageType
    lender            String?
    propertyAddress   String?
    ltv               Decimal?     @db.Decimal(5, 2)
    fixedPeriodMonths Int?
    indexedTo         String?
    spread            Decimal?     @db.Decimal(8, 5)
    createdAt         DateTime     @default(now())
    updatedAt         DateTime     @updatedAt
    deletedAt         DateTime?    @db.Timestamptz

    liability Liability @relation(fields: [liabilityId], references: [id], onDelete: Cascade)
}

model LoanLiability {
    id          String    @id @default(uuid())
    liabilityId String    @unique
    loanType    LoanType
    lender      String?
    purpose     String?
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    deletedAt   DateTime? @db.Timestamptz

    liability Liability @relation(fields: [liabilityId], references: [id], onDelete: Cascade)
}

model LiabilityTransaction {
    id                 String                   @id @default(uuid())
    liabilityId        String
    type               LiabilityTransactionType
    date               DateTime
    amount             Decimal                  @db.Decimal(20, 2)
    principalPart      Decimal?                 @db.Decimal(20, 2)
    interestPart       Decimal?                 @db.Decimal(20, 2)
    feesPart           Decimal?                 @db.Decimal(20, 2)
    currency           Currency                 @default(EUR)
    fxRate             Decimal?                 @db.Decimal(20, 10)
    financialAccountId String?
    note               String?
    createdAt          DateTime                 @default(now())
    updatedAt          DateTime                 @updatedAt
    deletedAt          DateTime?                @db.Timestamptz

    liability        Liability         @relation(fields: [liabilityId], references: [id], onDelete: Cascade)
    financialAccount FinancialAccount? @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)

    @@index([liabilityId, type])
    @@index([liabilityId, date(sort: Desc)])
    @@index([financialAccountId])
}

// ===========================================================================
// SNAPSHOT (historical wealth)
// ===========================================================================
model Snapshot {
    id                String                     @id @default(uuid())
    userId            String
    snapshotDate      DateTime                   @db.Date
    note              String?
    totalCash         Decimal                    @default(0) @db.Decimal(20, 2)
    totalInvestments  Decimal                    @default(0) @db.Decimal(20, 2)
    totalLiabilities  Decimal                    @default(0) @db.Decimal(20, 2)
    totalNetWorth     Decimal                    @default(0) @db.Decimal(20, 2)
    accountBalances   SnapshotAccountBalance[]
    assetValues       SnapshotAssetValue[]
    liabilityBalances SnapshotLiabilityBalance[]
    createdAt         DateTime                   @default(now())
    updatedAt         DateTime                   @updatedAt
    deletedAt         DateTime?                  @db.Timestamptz

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, snapshotDate])
    @@index([userId, snapshotDate(sort: Desc)])
}

model SnapshotAccountBalance {
    id               String    @id @default(uuid())
    snapshotId       String
    accountId        String?
    balance          Decimal   @db.Decimal(20, 2)
    originalCurrency Currency?
    originalValue    Decimal?  @db.Decimal(20, 2)
    fxRate           Decimal?  @db.Decimal(20, 10)
    createdAt        DateTime  @default(now())
    updatedAt        DateTime  @updatedAt
    deletedAt        DateTime? @db.Timestamptz

    snapshot Snapshot          @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
    account  FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

    @@unique([snapshotId, accountId])
}

model SnapshotAssetValue {
    id               String      @id @default(uuid())
    snapshotId       String
    assetId          String?
    quantity         Decimal?    @db.Decimal(20, 10)
    unitPrice        Decimal?    @db.Decimal(20, 8)
    totalValue       Decimal     @db.Decimal(20, 2)
    originalCurrency Currency?
    originalValue    Decimal?    @db.Decimal(20, 2)
    fxRate           Decimal?    @db.Decimal(20, 10)
    source           ValueSource @default(MANUAL)
    createdAt        DateTime    @default(now())
    updatedAt        DateTime    @updatedAt
    deletedAt        DateTime?   @db.Timestamptz

    snapshot Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
    asset    Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)

    @@unique([snapshotId, assetId])
}

model SnapshotLiabilityBalance {
    id               String    @id @default(uuid())
    snapshotId       String
    liabilityId      String?
    balance          Decimal   @db.Decimal(20, 2)
    originalCurrency Currency?
    originalValue    Decimal?  @db.Decimal(20, 2)
    fxRate           Decimal?  @db.Decimal(20, 10)
    createdAt        DateTime  @default(now())
    updatedAt        DateTime  @updatedAt
    deletedAt        DateTime? @db.Timestamptz

    snapshot  Snapshot   @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
    liability Liability? @relation(fields: [liabilityId], references: [id], onDelete: SetNull)

    @@unique([snapshotId, liabilityId])
}

model FxRate {
    id           String    @id @default(uuid())
    fromCurrency Currency
    toCurrency   Currency
    rate         Decimal   @db.Decimal(20, 10)
    date         DateTime  @db.Date
    source       String?
    createdAt    DateTime  @default(now())
    updatedAt    DateTime  @updatedAt
    deletedAt    DateTime? @db.Timestamptz

    @@unique([fromCurrency, toCurrency, date])
    @@index([date])
    @@index([fromCurrency, toCurrency])
}

// ===========================================================================
// IMPORT & TRANSACTIONS
// ===========================================================================
model Import {
    id                 String            @id @default(uuid())
    userId             String
    title              String
    financialAccountId String
    status             TransactionStatus @default(IMPORT_PENDING)
    transactions       Transaction[]
    files              ImportFile[]
    createdAt          DateTime          @default(now())
    updatedAt          DateTime          @updatedAt
    deletedAt          DateTime?         @db.Timestamptz

    user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
    financialAccount FinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([status])
}

model ImportFile {
    id        String    @id @default(uuid())
    importId  String
    filename  String
    filetype  FileType
    path      String
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime? @db.Timestamptz

    import Import @relation(fields: [importId], references: [id], onDelete: Cascade)

    @@index([importId])
}

model Transaction {
    id            String             @id @default(uuid())
    userId        String
    date          DateTime
    title         String
    note          String?
    icon          String?
    categoryId    String?
    subcategoryId String?
    importId      String?
    action        TransactionAction  @default(EXPENSES)
    status        TransactionStatus  @default(APPROVED)
    ignore        Boolean            @default(false)
    createdAt     DateTime           @default(now())
    updatedAt     DateTime           @updatedAt
    deletedAt     DateTime?          @db.Timestamptz
    media         TransactionMedia[]
    amounts       Amount[]

    transferId String?

    user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
    category     Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
    subcategory  Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
    import       Import?      @relation(fields: [importId], references: [id], onDelete: SetNull)
    transfer     Transfer?    @relation("TransferTransactions", fields: [transferId], references: [id], onDelete: SetNull)
    fromTransfer Transfer?    @relation("FromLeg")
    toTransfer   Transfer?    @relation("ToLeg")

    @@index([userId, date])
    @@index([transferId])
    @@index([importId])
    @@index([categoryId])
    @@index([subcategoryId])
}

model Transfer {
    id                String    @id @default(uuid())
    userId            String
    transferDate      DateTime
    note              String?
    fromTransactionId String?   @unique
    toTransactionId   String?   @unique
    createdAt         DateTime  @default(now())
    updatedAt         DateTime  @updatedAt
    deletedAt         DateTime? @db.Timestamptz

    user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
    fromTransaction Transaction?  @relation("FromLeg", fields: [fromTransactionId], references: [id], onDelete: SetNull)
    toTransaction   Transaction?  @relation("ToLeg", fields: [toTransactionId], references: [id], onDelete: SetNull)
    transactions    Transaction[] @relation("TransferTransactions")

    @@index([transferDate])
    @@index([fromTransactionId])
    @@index([toTransactionId])
    @@index([userId, transferDate])
}

model TransactionMedia {
    id            String    @id @default(uuid())
    transactionId String
    filename      String
    filetype      String
    path          String
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt
    deletedAt     DateTime? @db.Timestamptz

    transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

    @@index([transactionId])
}

model Amount {
    id                 String            @id @default(uuid())
    transactionId      String
    amount             Decimal           @db.Decimal(20, 2)
    currency           Currency
    action             TransactionAction @default(EXPENSES)
    financialAccountId String
    importReference    String?
    createdAt          DateTime          @default(now())
    updatedAt          DateTime          @updatedAt
    deletedAt          DateTime?         @db.Timestamptz

    financialAccount FinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)
    transaction      Transaction      @relation(fields: [transactionId], references: [id], onDelete: Cascade)

    @@index([transactionId])
    @@index([financialAccountId])
    @@index([action])
}

// ===========================================================================
// SUBSCRIPTIONS
// ===========================================================================
model Subscription {
    id                  String         @id @default(uuid())
    userId              String
    title               String
    description         String?
    amount              Decimal        @db.Decimal(20, 2)
    currency            Currency
    appearanceMode      AppearanceMode
    appearanceLogoIcon  String
    appearanceIconColor String         @default("#818a66")
    firstPayment        DateTime
    cycleNumber         Int            @default(1)
    cyclePeriod         CyclePeriod
    rememberPeriod      RememberPeriod
    financialAccountId  String
    isEnabled           Boolean
    createdAt           DateTime       @default(now())
    updatedAt           DateTime       @updatedAt
    deletedAt           DateTime?      @db.Timestamptz

    user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
    financialAccount FinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([financialAccountId])
    @@index([isEnabled])
}

// ===========================================================================
// CATEGORIES & SUBCATEGORIES
// ===========================================================================
model Category {
    id            String            @id @default(uuid())
    userId        String
    title         String
    for           TransactionAction
    icon          String
    color         String            @default("#8B5CF6")
    createdAt     DateTime          @default(now())
    updatedAt     DateTime          @updatedAt
    deletedAt     DateTime?         @db.Timestamptz
    transactions  Transaction[]
    subcategories Subcategory[]

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([for])
}

model Subcategory {
    id           String        @id @default(uuid())
    categoryId   String
    title        String
    icon         String
    createdAt    DateTime      @default(now())
    updatedAt    DateTime      @updatedAt
    deletedAt    DateTime?     @db.Timestamptz
    transactions Transaction[]

    category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

    @@index([categoryId])
}

// ===========================================================================
// MARKET DATA PROVIDERS
// ===========================================================================
model MarketDataProviderCredential {
    id         String   @id @default(uuid())
    userId     String
    providerId String
    ciphertext Bytes
    iv         Bytes
    authTag    Bytes
    algo       String   @default("aes256gcm-v1")
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, providerId])
    @@index([userId])
}

