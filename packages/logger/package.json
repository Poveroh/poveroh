{
    "name": "@poveroh/logger",
    "version": "0.0.0",
    "type": "module",
    "main": "./dist/index.js",
    "typings": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js"
        },
        "./server": {
            "types": "./dist/server/server.d.ts",
            "import": "./dist/server/server.js",
            "require": "./dist/server/server.js"
        },
        "./browser": {
            "types": "./dist/client/browser.d.ts",
            "import": "./dist/client/browser.js",
            "require": "./dist/client/browser.js"
        },
        "./telemetry": {
            "types": "./dist/server/telemetry.d.ts",
            "import": "./dist/server/telemetry.js",
            "require": "./dist/server/telemetry.js"
        },
        "./telemetry-next": {
            "types": "./dist/client/telemetry.d.ts",
            "import": "./dist/client/telemetry.js",
            "require": "./dist/client/telemetry.js"
        }
    },
    "private": true,
    "scripts": {
        "build": "tsc",
        "lint": "eslint . --max-warnings 0"
    },
    "dependencies": {
        "@logtail/node": "^0.5.0",
        "@logtail/winston": "^0.5.0",
        "@opentelemetry/auto-instrumentations-node": "^0.76.0",
        "@opentelemetry/exporter-logs-otlp-http": "^0.218.0",
        "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
        "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
        "@opentelemetry/host-metrics": "^0.38.3",
        "@opentelemetry/resources": "^2.7.1",
        "@opentelemetry/sdk-logs": "^0.218.0",
        "@opentelemetry/sdk-metrics": "^2.7.1",
        "@opentelemetry/sdk-node": "^0.218.0",
        "@opentelemetry/winston-transport": "^0.28.0",
        "@poveroh/types": "*",
        "winston": "^3.17.0",
        "winston-daily-rotate-file": "^5.0.0",
        "winston-transport": "^4.9.0"
    },
    "peerDependencies": {
        "@logtail/browser": "^0.5.0",
        "@vercel/otel": "^1.13.0"
    },
    "peerDependenciesMeta": {
        "@logtail/browser": {
            "optional": true
        },
        "@vercel/otel": {
            "optional": true
        }
    },
    "devDependencies": {
        "@poveroh/tsconfig": "*",
        "typescript": "^5.7.3"
    }
}
