{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "globalDependencies": [".env"],
    "globalEnv": ["NODE_ENV", "LOG_LEVEL", "SIGNOZ_ENABLED", "SIGNOZ_ENDPOINT"],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env", "LOG_LEVEL", "NODE_ENV"],
            "outputs": ["dist/**", ".next/**", "!.next/cache/**", "storybook-static/**"]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "check-types": {
            "dependsOn": ["^check-types"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "dev:worker": {
            "cache": false,
            "persistent": true
        }
    }
}
